<view wx:if="{{show}}" class="match-window">
  <image class="match-bg" src="/img/pipei.png" mode="aspectFill"></image>
  <view class="match-content">
    <view class="title">{{matchType}}匹配中</view>
    <view class="players">
      <view class="player">
        <image class="player-avatar" src="{{myAvatar}}" mode="aspectFill"></image>
        <text class="player-name">{{myAccount}}</text>
      </view>
      <text class="vs">VS</text>
      <view class="player">
        <image wx:if="{{opponentAvatar}}" class="player-avatar" src="{{opponentAvatar}}" mode="aspectFill"></image>
        <image wx:else class="player-avatar default-avatar" src="/img/default-avatar.png" mode="aspectFill"></image>
        <text class="player-name">{{opponentAccount || '???'}}</text>
      </view>
    </view>
    <view class="status">{{status}}</view>
    <view class="cancel-btn" bindtap="onCancel">取消匹配</view>
  </view>
</view>