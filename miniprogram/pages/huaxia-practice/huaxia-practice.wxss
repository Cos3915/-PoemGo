.container {
  width: 100%;
  min-height: 100vh;
  position: relative;
  font-family: "Noto Serif SC", serif;
}

.background {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  z-index: -1;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  padding-top: 80rpx;
}

.player-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.player-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  margin-bottom: 10rpx;
}

.player-name {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 5rpx;
}

.player-score {
  font-size: 32rpx;
  font-weight: bold;
  color: #8b4513;
}

.my-info .player-name {
  color: #3498db;
}

.my-info .player-score {
  color: #3498db;
}

.round-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.round-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.content-container {
  padding: 30rpx;
}

.question-card {
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 30rpx;
}

.question-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
  text-align: center;
}

.question-author {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 30rpx;
  text-align: center;
}

.question-content {
  font-size: 32rpx;
  line-height: 1.6;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.blank-container {
  margin-top: 20rpx;
}

.blank-text {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
  text-align: center;
}

.blank-input {
  width: 94%;
  height: 80rpx;
  border: 2rpx solid #a2c8b1ff;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  color: #333;
  text-align: center;
}

.button-container {
  display: flex;
  justify-content: space-between;
}

.exit-btn {
  flex: 1;
  height: 80rpx;
  background-color: #e76f62ff;
  color: white;
  font-size: 32rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
}

.submit-btn {
  flex: 1;
  height: 80rpx;
  background-color: #5aade4ff;
  color: white;
  font-size: 32rpx;
  border-radius: 10rpx;
}

.exit-confirm {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.confirm-content {
  background-color: white;
  border-radius: 20rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 500rpx;
}

.confirm-text {
  font-size: 32rpx;
  color: #333;
  display: block;
  text-align: center;
  margin-bottom: 30rpx;
}

.confirm-buttons {
  display: flex;
  justify-content: space-between;
}

.confirm-btn {
  flex: 1;
  height: 70rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.confirm-btn.cancel {
  background-color: #f0f0f0;
  color: #666;
  margin-right: 20rpx;
}

.confirm-btn.confirm {
  background-color: #88ad89ff;
  color: white;
}