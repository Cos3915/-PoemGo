.container {
  width: 100%;
  height: 100vh;
  position: relative;
  font-family: 'Noto Serif SC', serif;
  overflow: hidden;
}

.background {
  width: 100%;
  height: 100%;
  position: fixed;
  top: 0;
  left: 0;
}

.header {
  position: relative;
  padding: 100rpx 20rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 10;
}

.player-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.player-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  border: 2rpx solid #fff;
  margin-bottom: 10rpx;
}

.player-name {
  font-size: 24rpx;
  color: #333;
}

.score-board {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.token-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.countdown-text {
  font-size: 28rpx;
  color: #ff4444;
}

.chat-container {
  position: absolute;
  top: 300rpx;
  left: 0;
  right: 0;
  bottom: 120rpx;
  padding: 20rpx;
  overflow-y: auto;
  z-index: 10;
}

.message-item {
  margin-bottom: 20rpx;
  max-width: 85%;
  padding: 30rpx;
  border-radius: 20rpx;
}

.message-item.opponent {
  align-self: flex-start;
  background-color: rgba(255, 255, 255, 0.8);
}

.message-item.me {
  align-self: flex-end;
  background-color: rgba(128, 168, 168, 0.8);
  margin-left: auto;
}

.message-item.system {
  align-self: center;
  background-color: rgba(255, 255, 255, 0.6);
  max-width: 90%;
}

.message-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.input-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.9);
  z-index: 20;
}

.input-field {
  flex: 1;
  height: 80rpx;
  border: 2rpx solid #ccc;
  border-radius: 40rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  font-family: 'Noto Serif SC', serif;
}

.send-btn {
  width: 150rpx!important;
  height: 70rpx;
  border-radius: 40rpx;
  background-color: #80a8a8;
  color: white;
  font-size: 28rpx;
  border: none;
  margin-left: 20rpx;
  font-family: 'Noto Serif SC', serif;
}

.result-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.result-background {
  width: 700rpx;
  height: 500rpx;
  position: absolute;
}

.result-content {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 101;
}

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
  font-family: 'Noto Serif SC', serif;
}

.result-message {
  font-size: 32rpx;
  color: #333;
  text-align: center;
  margin-bottom: 60rpx;
  font-family: 'Noto Serif SC', serif;
}

.result-btn {
  width: 160rpx!important;
  height: 70rpx;
  border-radius: 30rpx;
  background-color: #80a8a8;
  color: white;
  font-size: 28rpx;
  border: none;
  font-family: 'Noto Serif SC', serif;
}