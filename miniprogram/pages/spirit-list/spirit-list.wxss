.container {
  padding: 20rpx;
  min-height: 100vh;
  position: relative;
  font-family: "Noto Serif SC", serif;
}

.background {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  z-index: -1;
  opacity: 0.8;
}

.header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  padding-top: 80rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 30rpx;
  margin-right: 30rpx;
}

.back-icon {
  font-size: 36rpx;
  color: #333;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.spirit-grid {
  display: flex;
  width: 555rpx;
  flex-wrap: wrap;
  justify-content: space-between;
}

.spirit-item {
  width: 35%;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  position: relative;
}

.spirit-image {
  width: 100%;
  height: 200rpx;
  border-radius: 10rpx;
  margin-bottom: 15rpx;
}

.spirit-name {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
  text-align: center;
  margin-bottom: 5rpx;
}

.locked-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.locked-text {
  color: #fff;
  font-size: 24rpx;
}