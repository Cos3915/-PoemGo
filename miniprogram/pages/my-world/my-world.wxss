.container {
  width: 100%;
  min-height: 100vh;
  position: relative;
  font-family: "Noto Serif SC", serif;
}

.background {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  z-index: -1;
}

.header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  padding-top: 80rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 30rpx;
  margin-right: 30rpx;
}

.back-icon {
  font-size: 36rpx;
  color: #333;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.profile-card {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.9);
  margin: 0 30rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 3rpx solid #f0f0f0;
}

.profile-info {
  flex: 1;
  margin-left: 30rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
  color: #333;
}

.level {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}

.level-bar {
  width: 100%;
  height: 8rpx;
  background-color: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 5rpx;
}

.level-progress {
  height: 100%;
  background-color: #89b791ff;
}

.level-text {
  font-size: 20rpx;
  color: #999;
}

.stats-card {
  display: flex;
  background-color: rgba(255, 255, 255, 0.9);
  margin: 30rpx;
  padding: 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #8b4513;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

.function-cards {
  margin: 0 30rpx 30rpx;
}

.function-card {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.9);
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.card-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.trophy-icon {
  background-color: #ece1a1ff;
}

.book-icon {
  background-color: #de90a0ff;
}

.spirit-icon {
  background-color: #9cabe1ff;
}

.settings-icon {
  background-color: #696969;
}

.card-content {
  flex: 1;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
  color: #333;
}

.card-description {
  font-size: 24rpx;
  color: #666;
}

.card-arrow {
  font-size: 28rpx;
  color: #999;
}