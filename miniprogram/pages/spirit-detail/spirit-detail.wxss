.container {
  padding: 30rpx;
  min-height: 100vh;
  position: relative;
  font-family: "Noto Serif SC", serif;
}

.background {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  z-index: -1;
  opacity: 0.8;
}

.header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  padding-top: 80rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 30rpx;
  margin-right: 30rpx;
}

.back-icon {
  font-size: 36rpx;
  color: #333;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.spirit-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.spirit-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 100rpx;
  margin-bottom: 30rpx;
}

.spirit-name {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 15rpx;
}

.spirit-info {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 30rpx;
}

.spirit-description {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  margin-bottom: 40rpx;
  padding: 0 20rpx;
}

.spirit-poem {
  border-top: 1rpx solid #e0e0e0;
  padding-top: 30rpx;
}

.poem-title {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.poem-author {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 20rpx;
}

.poem-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  font-style: italic;
}