.container {
  width: 100%;
  height: 100vh;
  position: relative;
  font-family: 'Noto Serif SC', serif;
}

.background {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.overlay {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  background-color: rgba(255, 255, 255, 0.4);
  z-index: 1;
}

.header {
  position: relative;
  padding: 20rpx;
  display: flex;
  align-items: center;
  z-index: 10;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.back-icon {
  font-size: 32rpx;
  color: #333;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  text-align: center;
}

.collect-btn {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.collect-icon {
  font-size: 36rpx;
  color: #999;
}

.collect-icon.collected {
  color: #80a8a8;
}

.content {
  position: relative;
  padding: 40rpx;
  z-index: 10;
}

.title-row {
  position: relative;
  margin-bottom: 20rpx;
  text-align: center;
}

.poetry-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.collect-btn {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
}

.poetry-author {
  font-size: 28rpx;
  color: #666;
  display: block;
  text-align: center;
  margin-bottom: 40rpx;
}

.poetry-content {
  font-size: 32rpx;
  color: #333;
  line-height: 1.8;
  display: block;
  text-align: center;
}