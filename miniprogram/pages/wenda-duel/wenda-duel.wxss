.container {
  width: 100%;
  height: 100vh;
  position: relative;
  font-family: 'Noto Serif SC', serif;
  overflow: hidden;
}

.background {
  width: 100%;
  height: 100%;
  position: fixed;
  top: 0;
  left: 0;
}

.header {
  position: relative;
  padding: 100rpx 20rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 10;
}

.content-container {
  position: absolute;
  top: 300rpx;
  left: 0;
  right: 0;
  bottom: 0;
  overflow-y: auto;
  z-index: 10;
}

.player-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.player-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  border: 2rpx solid #fff;
  margin-bottom: 10rpx;
}

.player-name {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 5rpx;
}

.player-score {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.round-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.round-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.opponent-result {
  position: relative;
  margin: 20rpx;
  padding: 20rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  text-align: center;
  z-index: 10;
}

.opponent-result-text {
  font-size: 28rpx;
  color: #333;
}

.question-card {
  position: relative;
  margin: 40rpx 20rpx;
  padding: 40rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  z-index: 10;
}

.question-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.8;
  margin-bottom: 40rpx;
}

.options-container {
  display: flex;
  flex-direction: column;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #ccc;
  border-radius: 10rpx;
  background-color: white;
}

.option-item.selected {
  border-color: #80a8a8;
  background-color: rgba(128, 168, 168, 0.1);
}

.option-label {
  width: 60rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.result-container {
  position: relative;
  margin: 40rpx 20rpx;
  padding: 40rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10;
}

.result-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 40rpx;
  text-align: center;
}

.next-btn {
  width: 200rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background-color: #80a8a8;
  color: white;
  font-size: 32rpx;
  border: none;
  font-family: 'Noto Serif SC', serif;
}

.result-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.result-background {
  width: 700rpx;
  height: 500rpx;
  position: absolute;
}

.result-content {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 101;
}

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
  font-family: 'Noto Serif SC', serif;
}

.result-message {
  font-size: 32rpx;
  color: #333;
  text-align: center;
  margin-bottom: 60rpx;
  font-family: 'Noto Serif SC', serif;
}

.result-btn {
  width: 160rpx!important;
  height: 70rpx;
  border-radius: 30rpx;
  background-color: #80a8a8;
  color: white;
  font-size: 28rpx;
  border: none;
  font-family: 'Noto Serif SC', serif;
}